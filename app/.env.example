# KW PV Tools — Next.js Build-Variablen
#
# Diese Variablen steuern NUR den Next.js-Build (Static Export).
# Alle Laufzeit-Einstellungen (E-Mail, Captcha, Rate-Limit) werden
# im WordPress-Admin unter Einstellungen → KW PV Tools konfiguriert.

# URL-Basis der WordPress REST-API (Same-Origin in Produktion)
NEXT_PUBLIC_API_BASE=/wp-json/kw-pv-tools/v1

# Captcha-Provider für den Build (nur für CI/lokale Entwicklung)
# In Produktion wird der Provider im WP-Admin gesetzt.
# Für lokale Entwicklung: none (kein Captcha)
CAPTCHA_PROVIDER=none
