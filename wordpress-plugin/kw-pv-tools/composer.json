{
  "name": "kw-baustoffe/kw-pv-tools",
  "description": "KW PV Tools – PV-Werkzeugsammlung für WordPress",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=7.4",
    "altcha-org/altcha": "^1.0",
    "yahnis-elsts/plugin-update-checker": "^5.4"
  },
  "autoload": {
    "psr-4": {
      "KW_PV_Tools\\Core\\": "includes/core/",
      "KW_PV_Tools\\Konfigurator\\": "includes/konfigurator/"
    }
  },
  "config": {
    "optimize-autoloader": true
  }
}
